@page "/tyme/availability"
@attribute [Authorize(Policy = "Tyme:Manager:Scoped")]

@using My.Client.Models

<PageTitle>Manage Availability</PageTitle>

<PageHeader Title="Availability Categories"
            Description="Projects flagged as team availability. Employees pick these when logging Vacation, OOO, Sick, or any other time off. Each entry dual-publishes a sanitized event to the workspace Team Availability calendar." />

@* Action buttons live above the table so they don't compete with the filter row for
   horizontal space. The MudTable's own ToolBarContent keeps the filter switches and
   search field — what a manager toggles while reading the list. *@
<MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Class="mb-3">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="AddCategory">Add Category</MudButton>
</MudStack>

<MudTable Items="@rows" Loading="@isLoading" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
    <ToolBarContent>
        <MudSwitch T="bool" Value="showInactive" Label="Show Inactive" Color="Color.Secondary"
                   ValueChanged="@OnShowInactiveChanged" />
        <MudSwitch T="bool" Class="ml-4" Value="showArchived" Label="View Archived" Color="Color.Secondary"
                   ValueChanged="@OnShowArchivedChanged" />
        <MudSpacer />
        <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"
                      Margin="Margin.Dense" Immediate="true" DebounceInterval="300" Style="max-width: 280px;" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Internal name</MudTh>
        <MudTh>Team calendar name</MudTh>
        <MudTh Style="width:120px;">Slug</MudTh>
        <MudTh Style="width:160px;">Group</MudTh>
        <MudTh Style="width:160px;">Organization</MudTh>
        <MudTh Style="width:140px;">Department</MudTh>
        <MudTh Style="width:100px;">Status</MudTh>
        <MudTh Style="width:80px; text-align:center;">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Internal name">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.BeachAccess" Size="Size.Small" Class="mr-2"
                         Style="color: var(--mud-palette-text-secondary);" />
                @context.Name
            </div>
        </MudTd>
        <MudTd DataLabel="Team calendar name">
            @* Always show the string that will actually appear on the team calendar.
               When DisplayName is set, it's that. When blank, the system falls back
               to the internal name — we render the internal name here too with a
               muted style so the manager sees the effective output, not a vague
               "(uses internal name)" promise. *@
            @if (!string.IsNullOrEmpty(context.TeamDisplayName))
            {
                <span>@context.TeamDisplayName</span>
            }
            else
            {
                <span style="color: var(--mud-palette-text-secondary);" title="No override set — falls back to the internal name">@context.Name</span>
            }
        </MudTd>
        <MudTd DataLabel="Slug">
            @if (!string.IsNullOrEmpty(context.Slug))
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">[@context.Slug]</MudChip>
            }
            else
            {
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-disabled);">—</MudText>
            }
        </MudTd>
        <MudTd DataLabel="Group">@(context.ProjectGroupName ?? "")</MudTd>
        <MudTd DataLabel="Organization">@(context.OrganizationName ?? "")</MudTd>
        <MudTd DataLabel="Department">@(context.DepartmentName ?? "")</MudTd>
        <MudTd DataLabel="Status">
            @if (context.IsArchived)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Dark">Archived</MudChip>
            }
            else if (!context.IsActive)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Inactive</MudChip>
            }
            else
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success">Active</MudChip>
            }
        </MudTd>
        <MudTd DataLabel="Actions" Style="text-align:center;">
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true">
                <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditCategory(context))">Edit</MudMenuItem>
                @if (!context.IsArchived)
                {
                    <MudMenuItem Icon="@(context.IsActive ? Icons.Material.Filled.Block : Icons.Material.Filled.CheckCircle)"
                                 OnClick="@(() => ToggleActive(context))">
                        @(context.IsActive ? "Set inactive" : "Set active")
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Archive" OnClick="@(() => ArchiveCategory(context))">Archive</MudMenuItem>
                }
                else
                {
                    <MudMenuItem Icon="@Icons.Material.Filled.Unarchive" OnClick="@(() => ArchiveCategory(context))">Unarchive</MudMenuItem>
                }
                @if (allowProjectDelete)
                {
                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@(() => RemoveCategory(context))">Delete</MudMenuItem>
                }
            </MudMenu>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="my-4" Align="Align.Center">
            No availability categories yet. Click <strong>Add Category</strong> to create one
            (e.g. Vacation, OOO, Sick).
        </MudText>
    </NoRecordsContent>
</MudTable>
