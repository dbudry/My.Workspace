        // Let Quill finish DOM updates and the scheduled attr-restore rAF passes complete.
        await Task.Delay(50);
        await HydrateEditorImagesAsync();
        await PullEditorHtmlAsync();
        MergeAttachmentFromDocument(doc);
        Snackbar.Add(forceLink ? $"Linked \"{doc.Name}\"." : $"Inserted image \"{doc.Name}\".", Severity.Success);
    }

