@page "/intranet/editor"
@implements IDisposable
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@using Microsoft.JSInterop
@using My.Shared
@using My.Shared.Constants
@using My.Shared.Dtos.Intranet
@using My.Shared.Rules
@using My.Client.Services
<PageTitle>Intranet Page Editor</PageTitle>

<ScopedAuthorizeView Scope="@Constants.Scopes.Intranet" MinimumRole="@Constants.Roles.Editor" ScopedOnly="true">
    <Authorized>
        @if (currentPage == null)
        {
            <PageHeader Title="Intranet Page Editor"
                        Description="Create and edit company pages with a full rich-text editor." />

            <SectionCard Title="Get Started" Icon="@Icons.Material.Filled.EditNote">
                <MudText Typo="Typo.body1" Class="mb-4">
                    Create a new page to begin editing. Preferred flow: create pages from the Navigation tree so they land in the menu automatically.
                </MudText>

                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="CreateNewPageAsync" Disabled="@isBusy">
                    @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Create New Page &amp; Start Editing
                </MudButton>

                <MudText Typo="Typo.caption" Class="mt-4 d-block">
                    Or load an existing page by ID.
                </MudText>
                <div class="d-flex align-center gap-2 mt-2">
                    <MudTextField @bind-Value="loadPageIdInput" Label="Existing Page ID" Variant="Variant.Outlined" Style="max-width: 320px;" />
                    <MudButton Variant="Variant.Outlined" OnClick="LoadExistingPageAsync" Disabled="@(isBusy || string.IsNullOrWhiteSpace(loadPageIdInput))">
                        Load
                    </MudButton>
                </div>
            </SectionCard>
        }
        else
        {
            <div class="intranet-editor-shell">
                <div class="intranet-editor-topbar">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <MudTextField @bind-Value="currentPage.Title" @bind-Value:after="SyncAppBarTitle"
                                      Label="Page title" Variant="Variant.Outlined"
                                      Required="true" Immediate="true" Class="intranet-editor-title-field" />

                        <MudSpacer />

                        <MudTooltip Text="Unpublished pages are hidden from the menu and page links for regular users. Editors can still preview drafts.">
                            <MudSwitch @bind-Value="currentPage.IsPublished" Label="Published" Color="Color.Primary" />
                        </MudTooltip>

                        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="ReloadPageAsync" Disabled="@isBusy">
                            Reload
                        </MudButton>
                        <MudTooltip Text="Create another page and switch to editing it (save this page first)">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.NoteAdd"
                                       OnClick="CreateNewPageAsync" Disabled="@isBusy">
                                New Page
                            </MudButton>
                        </MudTooltip>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.List"
                                   OnClick="NavigateToPagesList">
                            Pages
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Visibility"
                                   OnClick="ViewPageWithoutSaving" Disabled="@isBusy">
                            View page
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   OnClick="SavePageAsync" Disabled="@isBusy">
                            @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                            Save
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   OnClick="SaveAndViewPageAsync" Disabled="@isBusy">
                            Save &amp; view
                        </MudButton>
                    </MudStack>
                </div>

                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" KeepPanelsAlive="true"
                         ActivePanelIndex="activeEditorTab" ActivePanelIndexChanged="OnEditorTabChangedAsync">
                    <MudTabPanel Text="Content" Icon="@Icons.Material.Filled.Article">
                        <div class="intranet-editor-tab-panel">
                            <div class="intranet-editor-frame intranet-quill-host">
                                <div id="@QuillEditorId"></div>
                            </div>
                            <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">
                                Image and folder toolbar buttons open upload/library pickers for images, documents, and other allowed file types. Pasting or dragging a single external image prompts to link or copy. Allowed types and max sizes are configured as extension:MB pairs in App Settings → Intranet. The code button opens the page HTML for viewing, editing, or copying.
                            </MudText>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="Attachments" Icon="@Icons.Material.Filled.AttachFile">
                        <div class="intranet-editor-tab-panel">
                            <MudText Typo="Typo.body2" Class="mb-3">
                                Files linked to this page. Remove attachments that are no longer referenced in the page content.
                            </MudText>

                            @if (PageAttachments.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">No attachments on this page yet.</MudText>
                            }
                            else
                            {
                                <MudStack Row="true" Spacing="2" Class="mb-3" Wrap="Wrap.Wrap">
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Warning"
                                               StartIcon="@Icons.Material.Filled.DeleteSweep"
                                               OnClick="RemoveAllUnusedAttachmentsAsync"
                                               Disabled="@(isBusy || UnusedAttachmentCount == 0)">
                                        Remove all unused (@UnusedAttachmentCount)
                                    </MudButton>
                                    <MudButton Variant="Variant.Text" Size="Size.Small"
                                               OnClick="RefreshAttachmentUsageAsync" Disabled="isBusy">
                                        Refresh usage
                                    </MudButton>
                                </MudStack>

                                <MudTable Items="PageAttachments" Dense="true" Hover="true">
                                    <HeaderContent>
                                        <MudTh>Name</MudTh>
                                        <MudTh>Type</MudTh>
                                        <MudTh>Status</MudTh>
                                        <MudTh></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.Doc.Name</MudTd>
                                        <MudTd>@IntranetFileHelper.GetFileTypeLabel(context.Doc.MimeType, context.Doc.Name)</MudTd>
                                        <MudTd>
                                            @if (context.IsUsedInContent)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success">In content</MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Not in content</MudChip>
                                            }
                                        </MudTd>
                                        <MudTd>
                                            <MudStack Row="true" Spacing="0">
                                                @if (!context.IsUsedInContent)
                                                {
                                                    <MudTooltip Text="Detach from this page (file stays in Drive)">
                                                        <MudIconButton Icon="@Icons.Material.Filled.LinkOff" Size="Size.Small" Color="Color.Warning"
                                                                       aria-label="Remove unused attachment"
                                                                       OnClick="@(() => RemoveAttachmentAsync(context.Doc))"
                                                                       Disabled="isBusy" />
                                                    </MudTooltip>
                                                }
                                                @if (context.CanDeleteFromDrive)
                                                {
                                                    <MudTooltip Text="Delete from this page and Drive permanently">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                                       aria-label="Delete from page and Drive"
                                                                       OnClick="@(() => PurgeAttachmentFromDriveAsync(context.Doc))"
                                                                       Disabled="isBusy" />
                                                    </MudTooltip>
                                                }
                                            </MudStack>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="Page Settings" Icon="@Icons.Material.Filled.Settings">
                        <div class="intranet-editor-tab-panel intranet-settings-panel">
                            <MudTextField @bind-Value="currentPage.Slug" Label="Slug (URL friendly, optional)" Variant="Variant.Outlined"
                                          HelperText="Unique slug for a friendly link, e.g. /intranet/pages/it (save the page after changing)." Class="mb-3" />

                            <MudStack Spacing="1" Class="mb-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Parent page (optional)</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                    Nests this page under another in Manage Pages. This is separate from sidebar menu placement below.
                                </MudText>
                                @if (!string.IsNullOrWhiteSpace(currentPage.ParentPageTitle))
                                {
                                    <MudChip T="string" Color="Color.Default" Size="Size.Small">@currentPage.ParentPageTitle</MudChip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Not set</MudText>
                                }
                                <MudStack Row Spacing="1">
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="NavigateToPagesList">
                                        Manage Pages
                                    </MudButton>
                                    @if (!string.IsNullOrWhiteSpace(currentPage.ParentPageId))
                                    {
                                        <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Text"
                                                   OnClick="@(() => { currentPage.ParentPageId = null; })">
                                            Clear Parent
                                        </MudButton>
                                    }
                                </MudStack>
                            </MudStack>

                            <MudCard Elevation="1">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.subtitle2">Menu Location</MudText>
                                    </CardHeaderContent>
                                </MudCardHeader>
                                <MudCardContent>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                                        Where this page appears in the intranet sidebar for users.
                                    </MudText>
                                    @if (!string.IsNullOrWhiteSpace(selectedNavParentTitle))
                                    {
                                        <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2">Sidebar path:</MudText>
                                            <MudChip T="string" Color="Color.Primary" Size="Size.Medium">@selectedNavParentTitle</MudChip>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Not in the sidebar menu yet.</MudText>
                                    }
                                    <MudStack Row Spacing="2" Class="mt-3">
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AccountTree" OnClick="OpenNavPlacementPicker">
                                            Change Menu Location
                                        </MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.List" OnClick="@(() => Navigation.NavigateTo("intranet/navigation"))">
                                            Manage Full Menu
                                        </MudButton>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </div>
                    </MudTabPanel>
                </MudTabs>

                @if (!string.IsNullOrEmpty(saveError))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="ma-3">@saveError</MudAlert>
                }
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <MudAlert Severity="Severity.Warning">
            You need the Editor:Intranet (or higher) role to use the page editor.
        </MudAlert>
    </NotAuthorized>
</ScopedAuthorizeView>

<IntranetContentInsertDialog @bind-Visible="showInsertDialog"
                             Kind="insertKind"
                             InitialTab="insertDialogInitialTab"
                             PageId="@currentPage?.PageId"
                             SelectedLinkText="selectedLinkText"
                             OnFileInserted="HandleFileInsertedAsync"
                             OnUrlInserted="HandleUrlInsertedAsync" />

<MudDialog @bind-Visible="showImagePasteDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = false, CloseOnEscapeKey = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">Insert image</MudText>
    </TitleContent>
    <DialogContent>
        <div class="intranet-image-paste-dialog">
            @if (!string.IsNullOrEmpty(pastePreviewDataUrl))
            {
                <div class="intranet-image-paste-preview mb-2">
                    <MudImage Src="@pastePreviewDataUrl" Alt="Paste preview" ObjectFit="ObjectFit.Contain"
                              Class="intranet-image-paste-preview-img" />
                </div>
            }
            <MudText Typo="Typo.body2" Class="mb-3 intranet-image-paste-source" title="@pasteSourceTooltip">@pasteSourceDescription</MudText>
            @if (pasteShowChoiceRadios)
            {
                <MudRadioGroup @bind-Value="pasteChoice" T="string" Class="intranet-image-paste-options">
                    @if (pasteCanLink)
                    {
                        <MudRadio T="string" Value="@("link")" Color="Color.Primary" Dense="true">
                            Link to original URL
                        </MudRadio>
                    }
                    @if (pasteCanUpload)
                    {
                        <MudRadio T="string" Value="@("copy")" Color="Color.Primary" Dense="true">
                            Copy to library and embed on this page
                        </MudRadio>
                    }
                </MudRadioGroup>
            }
            else
            {
                <MudText Typo="Typo.subtitle2" Class="intranet-image-paste-options mb-2">
                    Copy to library and embed on this page
                </MudText>
            }
            @if (!string.IsNullOrEmpty(pasteCopyRequiredNotice) && pasteCanUpload && !pasteCanLink)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">@pasteCopyRequiredNotice</MudAlert>
            }
            @if (!string.IsNullOrEmpty(pasteFetchHint))
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">@pasteFetchHint</MudAlert>
            }
            @if (pasteChoice == "copy" && pasteCanUpload)
            {
                <MudTextField @bind-Value="pasteFileName" Label="File name" Variant="Variant.Outlined" Immediate="true"
                              HelperText="@IntranetFileHelper.UploadFileNameHelperText"
                              inputattributes="PasteFileNameInputAttributes"
                              Error="pasteFileNameInvalid" ErrorText="@IntranetFileHelper.UploadFileNameValidationError"
                              Class="mt-2 intranet-image-paste-filename" />
            }
            @if (!string.IsNullOrEmpty(pasteError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@pasteError</MudAlert>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelImagePasteDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfirmImagePasteAsync"
                   Disabled="@(isBusy || !CanConfirmImagePaste)">
            @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Insert
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="showHtmlCodeDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">HTML / Code</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-2">
            Page content as HTML. Edit directly or paste from another tool, then apply to update the editor.
        </MudText>
        <MudTextField @bind-Value="htmlCodeEditor" Label="Page HTML" Variant="Variant.Outlined"
                      Lines="16" Immediate="true"
                      Style="font-family: Consolas, monospace; font-size: 13px;" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyEditorHtmlAsync">
            Copy HTML
        </MudButton>
        <MudSpacer />
        <MudButton OnClick="CloseHtmlCodeDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyHtmlEditorAsync">
            Apply to Page
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="showNavPlacementPicker" Options="new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">Choose Navigation Location</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-2">
            Select the parent navigation item under which this page should appear.
        </MudText>
        <MudTextField @bind-Value="navPlacementSearch" Label="Search navigation items" Immediate="true"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mb-3" />
        <MudTable Items="FilteredNavPlacementOptions" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Location</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Title</MudTd>
                <MudTd>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => SelectNavPlacement(context))">
                        Select
                    </MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseNavPlacementPicker">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private IHttpClientFactory ClientFactory { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private IntranetMediaService IntranetMedia { get; set; } = null!;
    [Inject] private IntranetMediaPolicyService MediaPolicy { get; set; } = null!;
    [Inject] private My.Client.Services.IntranetNavigationEvents NavEvents { get; set; } = null!;

    [CascadingParameter(Name = "SetPageTitle")]
    private Action<string>? SetPageTitle { get; set; }

    private const string QuillEditorId = "intranet-quill-editor";

    private int activeEditorTab;

    private IntranetPageDto? currentPage;
    private string editorHtml = "";
    private bool isBusy;
    private string? saveError;

    private string loadPageIdInput = string.Empty;

    private bool showInsertDialog;
    private ContentInsertKind insertKind;
    private int insertDialogInitialTab;
    private string? selectedLinkText;

    private IntranetMediaPolicyDto _mediaPolicy = new();

    private bool showImagePasteDialog;
    private ImagePastePayload? pendingImagePaste;
    private string pasteChoice = "copy";
    private bool pasteCanLink;
    private string? pasteCopyRequiredNotice;
    private string? pasteFetchHint;
    private bool pasteCanUpload;
    private bool pasteShowChoiceRadios;
    private string pasteFileName = "";
    private string? pasteSourceDescription;
    private string? pasteSourceTooltip;
    private string? pastePreviewDataUrl;
    private string? pasteError;

    private bool pasteFileNameInvalid =>
        pasteChoice == "copy"
        && !string.IsNullOrWhiteSpace(pasteFileName)
        && !IntranetFileHelper.IsValidUploadFileName(IntranetFileHelper.NormalizeUploadFileName(pasteFileName));

    private bool CanConfirmImagePaste =>
        pendingImagePaste != null
        && pasteCanUpload
        && (pasteChoice == "link" && pasteCanLink
            || pasteChoice == "copy"
                && !string.IsNullOrWhiteSpace(pasteFileName)
                && IntranetFileHelper.IsValidUploadFileName(IntranetFileHelper.NormalizeUploadFileName(pasteFileName)));

    private Dictionary<string, object> PasteFileNameInputAttributes => new()
    {
        ["onfocusout"] = EventCallback.Factory.Create(this, NormalizePasteFileNameOnBlur)
    };

    private bool showHtmlCodeDialog;
    private string htmlCodeEditor = "";

    private List<IntranetNavigationItemDto> navPlacementOptions = new();
    private string? selectedNavParentId;
    private string? selectedNavParentTitle;
    private bool showNavPlacementPicker;
    private string navPlacementSearch = "";

    private DotNetObjectReference<IntranetEditor>? _dotNetRef;
    private string? _initializedForPageId;
    private MediaHydrationCoordinator? _hydration;
    private bool openedFromView;

    private string? GetPagesBase() => Constants.API.Intranet.Pages.Api;

    private async Task EnsureMediaPolicyLoadedAsync(bool forceRefresh = false) =>
        _mediaPolicy = await MediaPolicy.GetAsync(forceRefresh);

    private void NotifyMediaPolicyBlocked()
    {
        if (MediaPolicy.LastFetchFailed)
            Snackbar.Add(IntranetMediaPolicyService.FormatLoadFailureMessage(), Severity.Warning);
        else
            Snackbar.Add(IntranetMediaPolicyRules.NotConfiguredMessage, Severity.Warning);
    }

    [JSInvokable]
    public async Task OnImagePasteDetected(ImagePastePayload payload)
    {
        if (currentPage == null) return;

        try { await PullEditorHtmlAsync(); } catch { /* editor may not be mounted */ }
        await EnsureMediaPolicyLoadedAsync(forceRefresh: true);

        var policy = IntranetMediaPolicyService.ToPolicy(_mediaPolicy);
        if (!policy.IsConfigured)
        {
            NotifyMediaPolicyBlocked();
            return;
        }

        pendingImagePaste = payload;
        pasteError = null;
        pasteCopyRequiredNotice = null;
        pasteFetchHint = null;

        var requiresLibraryCopy = IntranetExternalFetchRules.RequiresLibraryCopy(payload.SourceUrl);
        var linkAllowedByPolicy = IsPasteLinkAllowedByPolicy(payload, policy);
        string? linkBlockedReason = null;
        var directlyLinkable = IntranetExternalFetchRules.IsDirectlyLinkable(payload.SourceUrl, out linkBlockedReason);

        pasteCanUpload = ComputePasteCanUpload(payload, policy, requiresLibraryCopy);

        // Never link-only: Link is optional only when Copy is also available.
        pasteCanLink = pasteCanUpload
            && linkAllowedByPolicy
            && directlyLinkable
            && !requiresLibraryCopy;

        if (requiresLibraryCopy && pasteCanUpload && string.IsNullOrWhiteSpace(payload.Base64))
        {
            var (fetched, fetchError) = await TryFetchPasteImageBase64Async(payload);
            if (!fetched && !string.IsNullOrWhiteSpace(fetchError))
                pasteFetchHint = fetchError;
        }

        if (!pasteCanLink && pasteCanUpload && requiresLibraryCopy)
            pasteCopyRequiredNotice = IntranetExternalFetchRules.GetCopyRequiredNotice(payload.SourceUrl);

        if (!pasteCanUpload)
        {
            Snackbar.Add(GetImagePolicyBlockMessage(payload, policy, linkBlockedReason), Severity.Warning);
            return;
        }

        pasteShowChoiceRadios = pasteCanLink;
        pasteChoice = "copy";
        pasteFileName = IntranetFileHelper.SuggestPageImageFileName(
            currentPage.Slug,
            currentPage.Title,
            payload.FileName,
            payload.AltText,
            payload.SourceUrl,
            GetExistingPageImageFileNames());
        (pasteSourceDescription, pasteSourceTooltip) = BuildPasteSourceDescription(payload);
        pastePreviewDataUrl = BuildPastePreviewDataUrl(payload);
        showImagePasteDialog = true;
        await InvokeAsync(StateHasChanged);
    }

    private static bool IsPasteLinkAllowedByPolicy(ImagePastePayload payload, IntranetMediaPolicy policy)
    {
        if (!payload.CanLink || string.IsNullOrWhiteSpace(payload.SourceUrl))
            return false;

        if (IntranetMediaPolicyRules.TryValidateLink(payload.SourceUrl, policy, out _))
            return true;

        if (!string.IsNullOrWhiteSpace(payload.FileName)
            && IntranetMediaPolicyRules.TryValidateLink(payload.FileName, policy, out _))
            return true;

        if (!string.IsNullOrWhiteSpace(payload.MimeType))
        {
            var synthetic = $"pasted-image.{InferExtensionFromMime(payload.MimeType)}";
            if (IntranetMediaPolicyRules.TryValidateLink(synthetic, policy, out _))
                return true;
        }

        return false;
    }

    private static string InferExtensionFromMime(string mimeType) =>
        mimeType.Trim().ToLowerInvariant() switch
        {
            "image/jpeg" => "jpg",
            "image/png" => "png",
            "image/gif" => "gif",
            "image/webp" => "webp",
            "image/bmp" => "bmp",
            "image/svg+xml" => "svg",
            _ when mimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase) => "jpg",
            _ => "jpg"
        };

    private static bool ComputePasteCanUpload(ImagePastePayload payload, IntranetMediaPolicy policy, bool requiresLibraryCopy)
    {
        if (!policy.IsConfigured)
            return false;

        // Clipboard/drag bytes: always offer copy; policy is enforced on Insert.
        if (!string.IsNullOrWhiteSpace(payload.Base64))
            return true;

        if (string.IsNullOrWhiteSpace(payload.SourceUrl))
            return payload.CanUpload || payload.Kind is "file" or "data";

        // URL pastes/drops: offer copy (fetch bytes on Insert when needed).
        if (requiresLibraryCopy || IsPasteLinkAllowedByPolicy(payload, policy))
            return true;

        return payload.CanLink || payload.CanUpload || payload.Kind is "url" or "file-url" or "file" or "data";
    }

    private static bool ImageMayBeCopied(ImagePastePayload img, IntranetMediaPolicy policy)
    {
        if (!policy.IsConfigured)
            return false;

        if (!string.IsNullOrWhiteSpace(img.Base64))
        {
            var name = img.FileName ?? "image.png";
            var mime = IntranetFileHelper.InferMimeType(name, img.MimeType);
            try
            {
                var len = Convert.FromBase64String(img.Base64).Length;
                return IntranetMediaPolicyRules.TryValidateUpload(name, mime, len, policy, out _);
            }
            catch
            {
                return false;
            }
        }

        if (img.Kind is "file" or "data")
            return true;

        var check = img.FileName ?? img.SourceUrl;
        return !string.IsNullOrWhiteSpace(check)
               && IntranetMediaPolicyRules.TryValidateLink(check, policy, out _);
    }

    private static string GetImagePolicyBlockMessage(ImagePastePayload payload, IntranetMediaPolicy policy, string? linkBlockedReason = null)
    {
        if (!string.IsNullOrWhiteSpace(linkBlockedReason)
            && !(payload.CanUpload || !string.IsNullOrWhiteSpace(payload.Base64)))
            return linkBlockedReason;

        if (payload.CanLink && !string.IsNullOrWhiteSpace(payload.SourceUrl)
            && !IntranetMediaPolicyRules.TryValidateLink(payload.SourceUrl, policy, out var linkError))
            return linkError ?? "File type is not allowed.";

        if (!string.IsNullOrWhiteSpace(payload.Base64))
        {
            var name = payload.FileName ?? "image.png";
            var mime = IntranetFileHelper.InferMimeType(name, payload.MimeType);
            try
            {
                var len = Convert.FromBase64String(payload.Base64).Length;
                if (!IntranetMediaPolicyRules.TryValidateUpload(name, mime, len, policy, out var uploadError)
                    && !string.IsNullOrWhiteSpace(uploadError))
                    return uploadError;
            }
            catch
            {
                // fall through to generic message
            }
        }

        return $"File type is not allowed. Allowed extensions: {IntranetMediaPolicyRules.FormatAllowedExtensions(policy)}.";
    }

    private void NormalizePasteFileNameOnBlur() =>
        pasteFileName = IntranetFileHelper.NormalizeUploadFileName(pasteFileName);

    private static (string Label, string? Tooltip) BuildPasteSourceDescription(ImagePastePayload payload)
    {
        if (!string.IsNullOrWhiteSpace(payload.SourceUrl) && payload.Kind is "url" or "file-url")
        {
            var url = payload.SourceUrl.Trim();
            try
            {
                var uri = new Uri(url);
                var host = uri.Host;
                var label = host.Contains("googleusercontent.com", StringComparison.OrdinalIgnoreCase)
                    || host.Contains("ggpht.com", StringComparison.OrdinalIgnoreCase)
                    ? "Image from Google"
                    : $"Image from {host}";
                return (label, url);
            }
            catch
            {
                return url.Length > 80 ? (url[..77] + "…", url) : (url, null);
            }
        }

        if (!string.IsNullOrWhiteSpace(payload.FileName))
            return ($"Clipboard image ({payload.FileName})", null);

        return ("Clipboard image", null);
    }

    private static string? BuildPastePreviewDataUrl(ImagePastePayload payload)
    {
        if (!string.IsNullOrWhiteSpace(payload.Base64))
        {
            var mime = IntranetFileHelper.InferMimeType(payload.FileName, payload.MimeType);
            return $"data:{mime};base64,{payload.Base64}";
        }

        if (payload.Kind == "url" && !string.IsNullOrWhiteSpace(payload.SourceUrl))
            return payload.SourceUrl.Trim();

        return null;
    }

    private IEnumerable<string> GetExistingPageImageFileNames()
    {
        var names = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        if (currentPage?.Documents != null)
        {
            foreach (var doc in currentPage.Documents)
            {
                if (string.IsNullOrWhiteSpace(doc.Name)) continue;
                if (IntranetFileHelper.ClassifyMimeType(doc.MimeType, doc.Name)
                    != IntranetFileHelper.FileTypeImage) continue;
                names.Add(doc.Name);
            }
        }

        var html = editorHtml;
        if (string.IsNullOrWhiteSpace(html) && currentPage != null)
            html = currentPage.ContentMarkdown;

        if (!string.IsNullOrWhiteSpace(html))
        {
            foreach (Match match in Regex.Matches(html, @"<img\b[^>]*\balt=[""']([^""']+)[""']", RegexOptions.IgnoreCase))
            {
                var alt = match.Groups[1].Value.Trim();
                if (!string.IsNullOrEmpty(alt))
                    names.Add(alt);
            }
        }

        return names;
    }

    private void CancelImagePasteDialog()
    {
        showImagePasteDialog = false;
        pendingImagePaste = null;
        pasteError = null;
    }

    private async Task ConfirmImagePasteAsync()
    {
        if (currentPage == null || pendingImagePaste == null) return;

        pasteError = null;
        isBusy = true;
        try
        {
            var policy = IntranetMediaPolicyService.ToPolicy(_mediaPolicy);

            if (pasteChoice == "link")
            {
                if (!IntranetMediaPolicyRules.TryValidateLink(pendingImagePaste.SourceUrl, policy, out var linkError))
                {
                    pasteError = linkError;
                    return;
                }

                if (!IntranetExternalFetchRules.IsDirectlyLinkable(
                        pendingImagePaste.SourceUrl, out var linkBlockedError))
                {
                    pasteError = linkBlockedError;
                    return;
                }

                var linked = await InsertPastedImageLinkAsync(pendingImagePaste);
                if (!linked)
                    return;

                CancelImagePasteDialog();
                Snackbar.Add("Image linked at original URL.", Severity.Success);
                return;
            }

            var normalizedFileName = IntranetFileHelper.NormalizeUploadFileName(pasteFileName);
            if (string.IsNullOrWhiteSpace(normalizedFileName)
                || !IntranetFileHelper.IsValidUploadFileName(normalizedFileName))
            {
                pasteError = IntranetFileHelper.UploadFileNameValidationError;
                return;
            }

            if (string.IsNullOrWhiteSpace(pendingImagePaste.Base64))
            {
                var (fetched, fetchError) = await TryFetchPasteImageBase64Async(pendingImagePaste);
                if (!fetched)
                {
                    pasteError = string.IsNullOrWhiteSpace(fetchError)
                        ? IntranetExternalFetchRules.GetBlockedUrlWithoutBytesMessage(pendingImagePaste.SourceUrl)
                        : fetchError;
                    return;
                }
            }

            var uploadMime = IntranetFileHelper.InferMimeType(normalizedFileName, pendingImagePaste.MimeType);
            var uploadLen = Convert.FromBase64String(pendingImagePaste.Base64!).Length;
            if (!IntranetMediaPolicyRules.TryValidateUpload(normalizedFileName, uploadMime, uploadLen, policy, out var uploadError))
            {
                pasteError = uploadError;
                return;
            }

            var doc = await UploadPastedImageAsync(pendingImagePaste, normalizedFileName);
            if (doc == null)
                return;

            var pasted = pendingImagePaste;
            showImagePasteDialog = false;
            pendingImagePaste = null;
            await InsertPastedCopyAsync(doc, pasted);
            var copyNotice = IntranetExternalFetchRules.GetCopyRequiredNotice(pasted.SourceUrl);
            Snackbar.Add(
                string.IsNullOrWhiteSpace(copyNotice)
                    ? $"Copied image as \"{normalizedFileName}\"."
                    : $"Copied image as \"{normalizedFileName}\". Display uses the library copy; original URL kept as reference.",
                Severity.Success);
        }
        catch (Exception ex)
        {
            pasteError = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task<bool> InsertPastedImageLinkAsync(ImagePastePayload payload)
    {
        var url = (payload.SourceUrl ?? "").Trim();
        if (string.IsNullOrEmpty(url))
        {
            pasteError = "No image URL to link.";
            return false;
        }

        if (!IntranetExternalFetchRules.IsDirectlyLinkable(url, out var blockedReason))
        {
            pasteError = blockedReason;
            return false;
        }

        var html = IntranetFileHelper.BuildExternalImageLinkHtml(url, payload.AltText);
        if (string.IsNullOrEmpty(html))
        {
            pasteError = "No image URL to link.";
            return false;
        }

        await JS.InvokeVoidAsync("quillEditor.insertHtml", QuillEditorId, html);
        await Task.Delay(50);

        if (!string.IsNullOrWhiteSpace(payload.Base64))
        {
            var mime = IntranetFileHelper.InferMimeType(payload.FileName, payload.MimeType);
            await JS.InvokeVoidAsync(
                "quillEditor.applyExternalImagePreview", QuillEditorId, url, payload.Base64, mime);
        }

        await HydrateEditorImagesAsync();
        await PullEditorHtmlAsync();
        return true;
    }

    private async Task InsertPastedCopyAsync(IntranetDocumentDto doc, ImagePastePayload payload)
    {
        if (currentPage == null) return;

        if (string.IsNullOrWhiteSpace(doc.DriveFileId))
        {
            Snackbar.Add("That file has no Drive id — pick another file or re-upload.", Severity.Warning);
            return;
        }

        await Task.Yield();

        if (!await JS.InvokeAsync<bool>("quillEditor.isMounted", QuillEditorId))
        {
            Snackbar.Add("Editor not ready — click in the content area and try again.", Severity.Warning);
            return;
        }

        var sourceUrl = (payload.SourceUrl ?? "").Trim();
        var preserveSource = !string.IsNullOrEmpty(sourceUrl)
            && !IntranetExternalFetchRules.IsDirectlyLinkable(sourceUrl, out _);

        var html = preserveSource
            ? IntranetFileHelper.BuildExternalImageLinkHtml(sourceUrl, payload.AltText, doc.DriveFileId)
            : IntranetFileHelper.BuildInsertHtml(doc);

        var inserted = await JS.InvokeAsync<bool>("quillEditor.insertHtml", QuillEditorId, html);
        if (!inserted)
        {
            Snackbar.Add("Could not insert content — click in the editor and try again.", Severity.Warning);
            return;
        }

        await Task.Delay(50);
        await HydrateEditorImagesAsync();
        await PullEditorHtmlAsync();
        MergeAttachmentFromDocument(doc);
    }

    private async Task<(bool Success, string? Error)> TryFetchPasteImageBase64Async(ImagePastePayload payload)
    {
        if (!string.IsNullOrWhiteSpace(payload.Base64))
            return (true, null);

        if (string.IsNullOrWhiteSpace(payload.SourceUrl))
            return (false, "No image URL to download.");

        var url = payload.SourceUrl.Trim();
        var skipClientFetch = Uri.TryCreate(url, UriKind.Absolute, out var uri)
            && IntranetExternalFetchRules.ShouldSkipClientFetch(uri);

        if (!skipClientFetch)
        {
            try
            {
                var fetched = await JS.InvokeAsync<FetchedImagePayload?>("quillEditor.fetchImageAsBase64", url);
                if (fetched != null && !string.IsNullOrWhiteSpace(fetched.Base64))
                {
                    ApplyFetchedImage(payload, fetched);
                    return (true, null);
                }
            }
            catch
            {
                // fall through to server fetch
            }
        }

        var (fromApi, apiError) = await FetchImageViaApiAsync(url);
        if (fromApi == null)
        {
            if (!string.IsNullOrWhiteSpace(apiError))
                return (false, apiError);

            if (uri != null)
            {
                var googleHint = IntranetExternalFetchRules.GetGoogleFetchBlockedHint(uri);
                if (!string.IsNullOrWhiteSpace(googleHint))
                    return (false, googleHint);
            }

            return (false, "Could not download this image for upload.");
        }

        ApplyFetchedImage(payload, fromApi);
        return (true, null);
    }

    private async Task<(FetchedImagePayload? Payload, string? Error)> FetchImageViaApiAsync(string url)
    {
        try
        {
            var client = ClientFactory.CreateClient(Constants.API.ClientName);
            var resp = await client.PostAsJsonAsync(Constants.API.Intranet.Documents.FetchExternalImage, new { Url = url });
            if (!resp.IsSuccessStatusCode)
            {
                var body = (await resp.Content.ReadAsStringAsync()).Trim();
                if (body.Length >= 2 && body[0] == '"' && body[^1] == '"')
                    body = body[1..^1];

                return (null, string.IsNullOrWhiteSpace(body)
                    ? $"Could not download image (HTTP {(int)resp.StatusCode})."
                    : body);
            }

            var result = await resp.Content.ReadFromJsonAsync<FetchExternalImageResultDto>();
            if (result == null || string.IsNullOrWhiteSpace(result.Base64))
                return (null, "The server did not return image data.");

            return (new FetchedImagePayload
            {
                Base64 = result.Base64,
                MimeType = result.MimeType,
                SuggestedFileName = result.SuggestedFileName
            }, null);
        }
        catch (Exception ex)
        {
            return (null, ex.Message);
        }
    }

    private static void ApplyFetchedImage(ImagePastePayload payload, FetchedImagePayload fetched)
    {
        payload.Base64 = fetched.Base64;
        if (!string.IsNullOrWhiteSpace(fetched.MimeType))
            payload.MimeType = fetched.MimeType;
        if (string.IsNullOrWhiteSpace(payload.FileName) && !string.IsNullOrWhiteSpace(fetched.SuggestedFileName))
            payload.FileName = fetched.SuggestedFileName;
    }

    private async Task<IntranetDocumentDto?> UploadPastedImageAsync(ImagePastePayload payload, string normalizedFileName)
    {
        if (string.IsNullOrWhiteSpace(payload.Base64))
        {
            pasteError = "No image data to upload.";
            return null;
        }

        var client = ClientFactory.CreateClient(Constants.API.ClientName);
        var body = new
        {
            FileName = normalizedFileName,
            MimeType = IntranetFileHelper.InferMimeType(normalizedFileName, payload.MimeType),
            ContentBase64 = payload.Base64,
            PageId = currentPage!.PageId,
            Caption = (string?)null
        };

        var resp = await client.PostAsJsonAsync(Constants.API.Intranet.Documents.Upload, body);
        if (!resp.IsSuccessStatusCode)
        {
            pasteError = await resp.Content.ReadAsStringAsync();
            return null;
        }

        var result = await resp.Content.ReadFromJsonAsync<UploadLibraryDocResultDto>();
        return result?.Document;
    }

