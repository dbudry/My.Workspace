    private async Task OnEditorTabChangedAsync(int index)
    {
        if (activeEditorTab == 0 && index != 0)
            await PullEditorHtmlAsync();

        if (index == 1)
            await RefreshAttachmentUsageAsync();

        if (index == 0 && currentPage != null)
        {
            try
            {
                var mounted = await JS.InvokeAsync<bool>("quillEditor.isMounted", QuillEditorId);
                if (!mounted)
                    _initializedForPageId = null;
            }
            catch
            {
                _initializedForPageId = null;
            }
        }

        activeEditorTab = index;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (currentPage == null || activeEditorTab != 0) return;

        var needsInit = _initializedForPageId != currentPage.PageId;
        if (!needsInit)
        {
            try
            {
                needsInit = !await JS.InvokeAsync<bool>("quillEditor.isMounted", QuillEditorId);
            }
            catch
            {
                needsInit = true;
            }
        }

        if (needsInit)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("quillEditor.init", QuillEditorId, _dotNetRef);
                await PushEditorHtmlAsync(editorHtml);
                _initializedForPageId = currentPage.PageId;
            }
            catch { /* quill script may not be loaded yet */ }
        }

        if (_initializedForPageId == currentPage.PageId)
        {
            try
            {
                if (await JS.InvokeAsync<bool>("quillEditor.isMounted", QuillEditorId))
                {
                    _hydration ??= new MediaHydrationCoordinator(() => HydrateEditorImagesAsync());
                    await _hydration.RequestAsync();
                }
            }
            catch { /* quill script may not be loaded yet */ }
        }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
        _ = JS.InvokeVoidAsync("quillEditor.destroy", QuillEditorId);
    }

    private async Task LoadNavigationPlacementOptionsAsync()
    {
        try
        {
            var client = ClientFactory.CreateClient(Constants.API.ClientName);
            navPlacementOptions = await client.GetFromJsonAsync<List<IntranetNavigationItemDto>>(Constants.API.Intranet.Navigation.Get) ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load navigation options: {ex.Message}", Severity.Warning);
            navPlacementOptions = new();
        }
    }

    private void ResolveCurrentNavigationPlacement()
    {
        if (currentPage == null) return;

        var allNav = FlattenNavTree(navPlacementOptions);

        var existing = allNav.FirstOrDefault(n => n.PageId == currentPage.PageId);
        if (existing != null)
        {
            selectedNavParentId = existing.ParentId;
            var parent = string.IsNullOrWhiteSpace(selectedNavParentId)
                ? null
                : allNav.FirstOrDefault(p => p.Id == selectedNavParentId);
            selectedNavParentTitle = parent?.Title ?? "(Top Level)";
        }
        else
        {
            selectedNavParentId = null;
            selectedNavParentTitle = null;
        }
    }

    private void OpenNavPlacementPicker()
    {
        navPlacementSearch = "";
        showNavPlacementPicker = true;
    }

    private void CloseNavPlacementPicker() => showNavPlacementPicker = false;

    private List<IntranetNavigationItemDto> FilteredNavPlacementOptions =>
        string.IsNullOrWhiteSpace(navPlacementSearch)
            ? FlattenNavForPicker(navPlacementOptions)
            : FlattenNavForPicker(navPlacementOptions)
                .Where(n => (n.Title ?? "").Contains(navPlacementSearch, StringComparison.OrdinalIgnoreCase))
                .ToList();

    private static List<IntranetNavigationItemDto> FlattenNavTree(IEnumerable<IntranetNavigationItemDto> items)
    {
        var result = new List<IntranetNavigationItemDto>();
        void Walk(IEnumerable<IntranetNavigationItemDto> list)
        {
            foreach (var i in list)
            {
                result.Add(i);
                if (i.Children?.Count > 0)
                    Walk(i.Children);
            }
        }
        Walk(items);
        return result;
    }

    private List<IntranetNavigationItemDto> FlattenNavForPicker(List<IntranetNavigationItemDto> items)
    {
        var result = new List<IntranetNavigationItemDto>();
        void Walk(IEnumerable<IntranetNavigationItemDto> list, string prefix = "")
        {
            foreach (var i in list)
            {
                result.Add(new IntranetNavigationItemDto
                {
                    Id = i.Id,
                    Title = string.IsNullOrEmpty(prefix) ? i.Title : $"{prefix} › {i.Title}",
                    ParentId = i.ParentId
                });
                if (i.Children?.Any() == true)
                    Walk(i.Children, string.IsNullOrEmpty(prefix) ? i.Title : $"{prefix} › {i.Title}");
            }
        }
        Walk(items);
        return result;
    }

    private void SelectNavPlacement(IntranetNavigationItemDto navItem)
    {
        selectedNavParentId = navItem.Id;
        selectedNavParentTitle = navItem.Title;
        CloseNavPlacementPicker();
    }

    private async Task EnsureNavigationPlacementAsync(HttpClient client, string pageId)
    {
        if (string.IsNullOrWhiteSpace(selectedNavParentId)) return;

        try
        {
            var existingNav = FlattenNavTree(navPlacementOptions)
                .FirstOrDefault(n => n.PageId == pageId);

            var navDto = new CreateIntranetNavigationItemDto
            {
                Title = currentPage!.Title,
                PageId = pageId,
                ParentId = selectedNavParentId,
                IsVisible = true,
                SortOrder = currentPage!.SortOrder
            };

            var navChanged = false;
            if (existingNav == null)
            {
                var createResp = await client.PostAsJsonAsync(Constants.API.Intranet.Navigation.Get, navDto);
                if (!createResp.IsSuccessStatusCode)
                {
                    var err = await createResp.Content.ReadAsStringAsync();
                    Snackbar.Add($"Page saved but failed to create navigation entry: {err}", Severity.Warning);
                }
                else
                {
                    navChanged = true;
                }
            }
            else if (existingNav.ParentId != selectedNavParentId
                     || !string.Equals(existingNav.Title, currentPage!.Title, StringComparison.Ordinal))
            {
                var updateResp = await client.PutAsJsonAsync($"{Constants.API.Intranet.Navigation.Get}/{existingNav.Id}", navDto);
                if (!updateResp.IsSuccessStatusCode)
                {
                    var err = await updateResp.Content.ReadAsStringAsync();
                    Snackbar.Add($"Page saved but failed to update navigation placement: {err}", Severity.Warning);
                }
                else
                {
                    navChanged = true;
                }
            }

            if (navChanged)
                NavEvents.NotifyChanged();

            await LoadNavigationPlacementOptionsAsync();
            ResolveCurrentNavigationPlacement();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Page saved but navigation placement update failed: {ex.Message}", Severity.Warning);
        }
    }

    private string BuildPageUrl(string pageId) => $"{GetPagesBase()}/{pageId}";

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        openedFromView = string.Equals(query["fromView"], "1", StringComparison.Ordinal)
            || string.Equals(query["fromView"], "true", StringComparison.OrdinalIgnoreCase);

        var loadId = query["pageId"] ?? query["load"] ?? query["id"];
        if (!string.IsNullOrWhiteSpace(loadId))
        {
            loadPageIdInput = loadId;
            await LoadPageByIdAsync(loadId);
        }
    }

    private async Task CreateNewPageAsync()
    {
        if (currentPage != null)
        {
            await PullEditorHtmlAsync();
            var confirm = await DialogService.ShowMessageBoxAsync(
                "Create new page?",
                "This creates a separate page and switches the editor to it. Save the current page first if you have changes to keep.",
                yesText: "New Page",
                cancelText: "Cancel");
            if (confirm != true)
                return;
        }

        isBusy = true;
        saveError = null;
        try
        {
            var client = ClientFactory.CreateClient(Constants.API.ClientName);
            var createDto = new CreateIntranetPageDto
            {
                Title = "New Intranet Page " + DateTime.Now.ToString("yyyy-MM-dd HH:mm"),
                IsPublished = true,
                SortOrder = 0
            };

            var response = await client.PostAsJsonAsync(GetPagesBase(), createDto);
            if (!response.IsSuccessStatusCode)
            {
                var err = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to create page: {err}", Severity.Error);
                return;
            }

            var created = await response.Content.ReadFromJsonAsync<IntranetPageDto>();
            if (created != null)
            {
                currentPage = created;
                editorHtml = "";
                _initializedForPageId = null;
                await Task.Yield();
                await LoadNavigationPlacementOptionsAsync();
                SyncAppBarTitle();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating page: {ex.Message}", Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task LoadExistingPageAsync()
    {
        if (string.IsNullOrWhiteSpace(loadPageIdInput)) return;
        await LoadPageByIdAsync(loadPageIdInput.Trim());
        loadPageIdInput = string.Empty;
    }

    private async Task LoadPageByIdAsync(string pageId)
    {
        isBusy = true;
        saveError = null;
        try
        {
            var client = ClientFactory.CreateClient(Constants.API.ClientName);
            var loaded = await client.GetFromJsonAsync<IntranetPageDto>(BuildPageUrl(pageId));
            if (loaded != null)
            {
                currentPage = loaded;
                editorHtml = IntranetFileHelper.PrepareDriveImageHtmlForView(
                    loaded.ContentMarkdown ?? "", loaded.Documents);
                _initializedForPageId = null;
                await Task.Yield();
                await LoadNavigationPlacementOptionsAsync();
                ResolveCurrentNavigationPlacement();
                await RefreshAttachmentUsageAsync();
                await EnsureMediaPolicyLoadedAsync(forceRefresh: true);
                SyncAppBarTitle();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load page: {ex.Message}", Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private void SyncAppBarTitle()
    {
        if (currentPage == null)
            return;

        SetPageTitle?.Invoke(string.IsNullOrWhiteSpace(currentPage.Title)
            ? "Intranet Page Editor"
            : currentPage.Title);
    }

    private async Task RefreshAttachmentUsageAsync()
    {
        if (currentPage == null) return;
        if (activeEditorTab == 0)
            await PullEditorHtmlAsync();

        var html = currentPage.ContentMarkdown ?? editorHtml ?? "";
        var client = ClientFactory.CreateClient(Constants.API.ClientName);
        var rows = new List<PageAttachmentRow>();

        foreach (var doc in (currentPage.Documents ?? new()).OrderBy(d => d.SortOrder))
        {
            IReadOnlyList<IntranetDocumentPageUsageDto> usedOn = new List<IntranetDocumentPageUsageDto>();
            if (!string.IsNullOrWhiteSpace(doc.DocumentId))
            {
                try
                {
                    var detail = await client.GetFromJsonAsync<IntranetDocumentDto>(
                        $"{Constants.API.Intranet.Documents.GetById}{doc.DocumentId}");
                    if (detail?.UsedOnPages != null)
                        usedOn = detail.UsedOnPages;
                }
                catch
                {
                    // usage lookup is best-effort for action buttons
                }
            }

            rows.Add(new PageAttachmentRow
            {
                Doc = doc,
                IsUsedInContent = IntranetFileHelper.IsDriveFileReferencedInHtml(html, doc.DriveFileId),
                UsedOnPages = usedOn,
                CanDeleteFromDrive = IntranetFileHelper.CanPurgeDocumentFromSinglePage(usedOn, currentPage.PageId)
            });
        }

        PageAttachments = rows;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RemoveAttachmentAsync(IntranetPageDocumentDto doc)
    {
        if (currentPage == null || string.IsNullOrWhiteSpace(doc.DocumentId)) return;

        var confirm = await DialogService.ShowMessageBoxAsync(
            "Remove attachment?",
            $"Remove \"{doc.Name}\" from this page? The file stays in Drive.",
            yesText: "Remove",
            cancelText: "Cancel");
        if (confirm != true) return;

        isBusy = true;
        try
        {
            var client = ClientFactory.CreateClient(Constants.API.ClientName);
            var resp = await client.DeleteAsync($"{BuildPageUrl(currentPage.PageId)}/documents/{doc.DocumentId}");
            if (!resp.IsSuccessStatusCode)
            {
                Snackbar.Add(await resp.Content.ReadAsStringAsync(), Severity.Error);
                return;
            }

            currentPage.Documents?.RemoveAll(d => d.DocumentId == doc.DocumentId);
            await RefreshAttachmentUsageAsync();
            Snackbar.Add($"Removed \"{doc.Name}\" from this page.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task PurgeAttachmentFromDriveAsync(IntranetPageDocumentDto doc)
    {
        if (currentPage == null || string.IsNullOrWhiteSpace(doc.DocumentId)) return;

        var row = PageAttachments.FirstOrDefault(r => r.Doc.DocumentId == doc.DocumentId);
        var usedOn = row?.UsedOnPages ?? Array.Empty<IntranetDocumentPageUsageDto>();
        if (!IntranetFileHelper.CanPurgeDocumentFromSinglePage(usedOn, currentPage.PageId))
        {
            Snackbar.Add("This file is also used on other pages — delete it from the Documents Library instead.", Severity.Warning);
            return;
        }

        var message = IntranetFileHelper.BuildLibraryDeleteMessage(doc.Name, usedOn);
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Delete from page and Drive?",
            message,
            yesText: "Delete permanently",
            cancelText: "Cancel");
        if (confirm != true) return;

        isBusy = true;
        try
        {
            var client = ClientFactory.CreateClient(Constants.API.ClientName);
            var resp = await client.DeleteAsync($"{Constants.API.Intranet.Documents.GetById}{doc.DocumentId}");
            if (!resp.IsSuccessStatusCode)
            {
                Snackbar.Add(await resp.Content.ReadAsStringAsync(), Severity.Error);
                return;
            }

            if (IntranetFileHelper.IsDriveFileReferencedInHtml(currentPage.ContentMarkdown ?? editorHtml, doc.DriveFileId))
            {
                var stripped = IntranetFileHelper.StripDriveFileReferencesFromHtml(
                    currentPage.ContentMarkdown ?? editorHtml, doc.DriveFileId);
                currentPage.ContentMarkdown = stripped;
                editorHtml = stripped;
                if (activeEditorTab == 0)
                    await PushEditorHtmlAsync(stripped);
            }

            currentPage.Documents?.RemoveAll(d => d.DocumentId == doc.DocumentId);
            await RefreshAttachmentUsageAsync();
            Snackbar.Add($"\"{doc.Name}\" deleted from Drive and removed from this page.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RemoveAllUnusedAttachmentsAsync()
    {
        var unused = PageAttachments.Where(a => !a.IsUsedInContent).Select(a => a.Doc).ToList();
        if (unused.Count == 0) return;

        var confirm = await DialogService.ShowMessageBoxAsync(
            "Remove unused attachments?",
            $"Remove {unused.Count} attachment(s) that are not referenced in the page content?",
            yesText: "Remove all",
            cancelText: "Cancel");
        if (confirm != true) return;

        isBusy = true;
        try
        {
            var client = ClientFactory.CreateClient(Constants.API.ClientName);
            foreach (var doc in unused)
            {
                if (string.IsNullOrWhiteSpace(doc.DocumentId)) continue;
                var resp = await client.DeleteAsync($"{BuildPageUrl(currentPage!.PageId)}/documents/{doc.DocumentId}");
                if (!resp.IsSuccessStatusCode)
                {
                    Snackbar.Add(await resp.Content.ReadAsStringAsync(), Severity.Error);
                    return;
                }
            }

            currentPage!.Documents?.RemoveAll(d => unused.Any(u => u.DocumentId == d.DocumentId));
            await RefreshAttachmentUsageAsync();
            Snackbar.Add($"Removed {unused.Count} unused attachment(s).", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ReloadPageAsync()
    {
        if (currentPage == null) return;
        await LoadPageByIdAsync(currentPage.PageId);
    }

    private void NavigateToPagesList()
    {
        if (currentPage == null)
        {
            Navigation.NavigateTo("intranet/pages");
            return;
        }

        Navigation.NavigateTo($"intranet/pages?fromEditor={Uri.EscapeDataString(currentPage.PageId)}");
    }

    private void ViewPageWithoutSaving()
    {
        if (currentPage == null) return;
        Navigation.NavigateTo(IntranetPageUrlHelper.GetViewPath(currentPage.PageId, currentPage.Slug));
    }

    private async Task SaveAndViewPageAsync()
    {
        if (currentPage == null) return;
        await SavePageAsync();
        if (!isBusy && string.IsNullOrEmpty(saveError) && currentPage != null)
            Navigation.NavigateTo(IntranetPageUrlHelper.GetViewPath(currentPage.PageId, currentPage.Slug));
    }

    private async Task SavePageAsync()
    {
        if (currentPage == null) return;

        isBusy = true;
        saveError = null;
        try
        {
            await PullEditorHtmlAsync();
            currentPage.ContentMarkdown = IntranetFileHelper.NormalizeDriveImageHtmlForStorage(currentPage.ContentMarkdown);

            var client = ClientFactory.CreateClient(Constants.API.ClientName);
            var updateDto = new UpdateIntranetPageDto
            {
                Title = currentPage.Title,
                Slug = currentPage.Slug,
                ParentPageId = currentPage.ParentPageId,
                ContentMarkdown = currentPage.ContentMarkdown,
                SortOrder = currentPage.SortOrder,
                IsPublished = currentPage.IsPublished
            };

            var response = await client.PutAsJsonAsync(BuildPageUrl(currentPage.PageId), updateDto);
            if (!response.IsSuccessStatusCode)
            {
                var err = await response.Content.ReadAsStringAsync();
                saveError = $"Save failed: {err}";
                Snackbar.Add(saveError, Severity.Error);
                return;
            }

            var saved = await response.Content.ReadFromJsonAsync<IntranetPageDto>();
            if (saved != null)
            {
                currentPage = saved;
                editorHtml = saved.ContentMarkdown ?? editorHtml;
                await EnsureNavigationPlacementAsync(client, saved.PageId);
                Snackbar.Add("Page saved.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            saveError = ex.Message;
            Snackbar.Add($"Save error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

