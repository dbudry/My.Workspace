    private void MergeAttachmentFromDocument(IntranetDocumentDto doc)
    {
        if (currentPage == null) return;

        currentPage.Documents ??= new List<IntranetPageDocumentDto>();
        var existing = currentPage.Documents.FirstOrDefault(d => d.DriveFileId == doc.DriveFileId);
        if (existing == null)
        {
            currentPage.Documents.Add(new IntranetPageDocumentDto
            {
                DocumentId = doc.DocumentId,
                DriveFileId = doc.DriveFileId,
                Name = doc.Name,
                MimeType = doc.MimeType,
                WebViewLink = doc.WebViewLink,
                ThumbnailLink = doc.ThumbnailLink,
                SortOrder = currentPage.Documents.Count
            });
        }
        else
        {
            existing.Name = doc.Name;
            existing.MimeType = doc.MimeType;
            existing.WebViewLink = doc.WebViewLink;
            existing.ThumbnailLink = doc.ThumbnailLink;
        }
        currentPage.Documents = currentPage.Documents.OrderBy(d => d.SortOrder).ToList();
        _ = RefreshAttachmentUsageAsync();
    }
}