<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudPaper Class="pa-6 mb-6" Elevation="0" Outlined="true" Style="border-radius: 8px;">
        <MudText Typo="Typo.h3" GutterBottom="true">My Workspace</MudText>
        <MudText Typo="Typo.subtitle1" Class="mb-4">
            
        </MudText>
        <MudDivider Class="my-4" />
        <MudText Class="mb-4">
           
        </MudText>
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudCard>
                <MudCardMedia Image="img/DashboardLandingPage.png" Height="200" />
                <MudCardContent>
                    <MudText Typo="Typo.h6">Dashboard</MudText>
                    <MudText Typo="Typo.body2">
                        This is a place where you can find reporting, track your progress, see how much time you spend per projects.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudCard>
                <MudCardMedia Image="img/CalendarLandingPage.png" Height="200" />
                <MudCardContent>
                    <MudText Typo="Typo.h6">Calendar</MudText>
                    <MudText Typo="Typo.body2">
                        Schedule your work time, track your progress, with Calendar you can see your progress by month, week, day.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudCard>
                <MudCardMedia Image="img/TrackedTasksTable.png" Height="200" />
                <MudCardContent>
                    <MudText Typo="Typo.h6">Task table</MudText>
                    <MudText Typo="Typo.body2">
                        This is a place where you can filter, review and examine your progress. It is up to you, in what are you interested.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>
