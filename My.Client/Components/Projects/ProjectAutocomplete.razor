@namespace My.Client.Components.Projects
@using My.Client.Models

@*
    Shared project picker. Name on the left, optional calendar slug chip on the right.

    Typing notes (MudBlazor 9 MudAutocomplete):
    - SelectOnActivation defaults to true and re-selects the whole field when focus
      re-enters after a search re-render — that collapses multi-character input to one letter.
    - We force SelectOnActivation=false so users can type project names normally.
    - CoerceText=false keeps free-typed text until an item is chosen.
    - Modal=false avoids the popover overlay stealing focus from the input.
    - OpenOnFocus still opens the suggestion list when the field is focused.
*@

<MudAutocomplete T="Project" Value="Value" ValueChanged="ValueChanged"
                 Label="@Label" Variant="@Variant" Margin="@Margin" Dense="@Dense"
                 Clearable="true"
                 OpenOnFocus="true"
                 CoerceText="false"
                 CoerceValue="false"
                 SelectOnActivation="false"
                 ResetValueOnEmptyText="true"
                 Strict="true"
                 DebounceInterval="250"
                 MaxItems="25"
                 Modal="false"
                 Placeholder="@Placeholder"
                 AdornmentIcon="@Icons.Material.Filled.Search"
                 AdornmentColor="Color.Default"
                 SearchFunc="SearchFunc"
                 ToStringFunc="@(p => p?.DisplayName ?? string.Empty)"
                 Style="@Style" Class="@Class">
    <ItemTemplate Context="project">
        <div class="d-flex align-center justify-space-between" style="width: 100%;">
            <span>@project.DisplayName</span>
            @if (!string.IsNullOrEmpty(project.FullSlug))
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="ml-2">
                    [@project.FullSlug]
                </MudChip>
            }
        </div>
    </ItemTemplate>
    <NoItemsTemplate>
        <MudText Typo="Typo.body2" Class="px-3 py-2" Style="color: var(--mud-palette-text-secondary);">
            No matching projects. Try a different name or slug.
        </MudText>
    </NoItemsTemplate>
</MudAutocomplete>

@code {
    [Parameter] public Project? Value { get; set; }
    [Parameter] public EventCallback<Project?> ValueChanged { get; set; }
    [Parameter] public Func<string?, CancellationToken, Task<IEnumerable<Project>>> SearchFunc { get; set; } = null!;
    [Parameter] public string Label { get; set; } = "Project";
    [Parameter] public string Placeholder { get; set; } = "Type to search projects…";
    [Parameter] public Variant Variant { get; set; } = Variant.Text;
    [Parameter] public Margin Margin { get; set; } = Margin.Dense;
    // Compact list rendering. Defaults to true (inline pickers); dialogs pass Dense="false".
    [Parameter] public bool Dense { get; set; } = true;
    [Parameter] public string? Style { get; set; }
    [Parameter] public string? Class { get; set; }
}
