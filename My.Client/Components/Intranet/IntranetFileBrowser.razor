@using MudBlazor
@using My.Shared
@using My.Shared.Dtos.Intranet

@* Library: Tyme-style full-page spinner while Drive list loads. *@
@if (Mode == IntranetFileBrowserMode.Library && isLoading)
{
    <PageLoader IsLoading="true" />
}
else
{
    <MudStack Spacing="3">
    @if (Mode == IntranetFileBrowserMode.Library)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Company Drive folder — all files here are available for pages.
        </MudText>
    }

    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="search" Placeholder="Search files..." Immediate="true" DebounceInterval="400"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Style="min-width: 220px; max-width: 320px;"
                      OnDebounceIntervalElapsed="ApplyFiltersAsync" />

        @if (string.IsNullOrWhiteSpace(FixedFileTypeFilter))
        {
            <MudSelect T="string" Value="fileTypeFilter" Label="Type" Variant="Variant.Outlined" Dense="true"
                       Style="min-width: 140px;" ValueChanged="OnFileTypeFilterChanged">
                @foreach (var opt in FileTypeOptions)
                {
                    <MudSelectItem Value="@opt.Value">@opt.Label</MudSelectItem>
                }
            </MudSelect>
        }

        <MudSelect T="string" Value="sortBy" Label="Sort by" Variant="Variant.Outlined" Dense="true"
                   Style="min-width: 140px;" ValueChanged="OnSortByChanged">
            @foreach (var opt in SortOptions)
            {
                <MudSelectItem Value="@opt.Value">@opt.Label</MudSelectItem>
            }
        </MudSelect>

        <MudIconButton Icon="@(sortDir == "desc" ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                       aria-label="Toggle sort direction" Size="Size.Small" OnClick="ToggleSortDirectionAsync" />

        @if (!HideUploadButton)
        {
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Upload"
                       OnClick="OpenUploadDialog" Disabled="isBusy">
                Upload
            </MudButton>
        }
    </MudStack>

    <MudTable Items="files" Dense="true" Hover="true" Loading="@(Mode != IntranetFileBrowserMode.Library && isLoading)">
        <HeaderContent>
            <MudTh Style="width: 40px;"></MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Modified</MudTh>
            <MudTh>Size</MudTh>
            <MudTh>Used on</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudIcon Icon="@GetTypeIcon(context.MimeType)" Size="Size.Small" />
            </MudTd>
            <MudTd>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.body2">@context.Name</MudText>
                    @if (context.IsFeatured)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                    }
                </MudStack>
            </MudTd>
            <MudTd>@IntranetFileHelper.GetFileTypeLabel(context.MimeType, context.Name)</MudTd>
            <MudTd>@(context.DriveLastModified?.ToLocalTime().ToString("g") ?? "—")</MudTd>
            <MudTd>@IntranetFileHelper.FormatFileSize(context.SizeBytes)</MudTd>
            <MudTd>
                @{
                    var usedOnPages = context.UsedOnPages ?? new();
                    var usedOnLabel = IntranetFileHelper.FormatUsedOnTableLabel(usedOnPages);
                    var usedOnTooltip = IntranetFileHelper.FormatUsedOnTooltip(usedOnPages);
                    var allAttachedOnly = usedOnPages.Count > 0 && usedOnPages.All(p => !p.IsReferencedInContent);
                }
                @if (usedOnPages.Count > 0)
                {
                    @if (!string.IsNullOrEmpty(usedOnTooltip) && usedOnPages.Count > 1)
                    {
                        <MudTooltip Text="@usedOnTooltip">
                            <MudText Typo="Typo.caption" Color="@(allAttachedOnly ? Color.Warning : Color.Default)">@usedOnLabel</MudText>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="@(allAttachedOnly ? Color.Warning : Color.Default)">@usedOnLabel</MudText>
                    }
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="1">
                    @if (Mode == IntranetFileBrowserMode.Picker)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(() => SelectFileAsync(context))" Disabled="isBusy">
                            Insert
                        </MudButton>
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(context.WebViewLink))
                        {
                            <MudTooltip Text="Open in Google Drive">
                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                               aria-label="Open in Google Drive"
                                               OnClick="@(() => OpenDriveLink(context.WebViewLink))" />
                            </MudTooltip>
                        }
                        <MudTooltip Text="Edit display name">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           aria-label="Edit display name"
                                           OnClick="@(() => OpenEditDialog(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Delete from library and Drive">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           aria-label="Delete file"
                                           OnClick="@(() => DeleteLibraryFileAsync(context))" />
                        </MudTooltip>
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                No files found. Upload a file or check App Settings for the Drive parent folder ID.
            </MudText>
        </NoRecordsContent>
    </MudTable>
</MudStack>

}

<MudDialog @bind-Visible="showUploadDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6">Upload to Drive Folder</MudText></TitleContent>
    <DialogContent>
        @if (string.IsNullOrEmpty(uploadBase64))
        {
            <FileDropZone Title="Upload to library"
                          Description="File is saved to the company Drive folder."
                          OnFileSelected="OnUploadFileSelected"
                          OnFileReady="ApplyUploadFileAsync" />
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-3 mb-2">
                @if (ShowImageUploadPreview && UploadPreviewDataUrl != null)
                {
                    <MudImage Src="@UploadPreviewDataUrl" Alt="Upload preview" ObjectFit="ObjectFit.Contain"
                              Style="max-height: 180px; width: 100%; border-radius: 4px;" Class="mb-2" />
                }
                <MudTextField @bind-Value="uploadDisplayName" Label="File name" Variant="Variant.Outlined" Immediate="true"
                              HelperText="@IntranetFileHelper.UploadFileNameHelperText"
                              inputattributes="UploadNameInputAttributes"
                              Error="uploadFileNameInvalid" ErrorText="@IntranetFileHelper.UploadFileNameValidationError" Class="mb-1" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                    Original: @uploadFileName (@IntranetFileHelper.FormatFileSize(uploadFileSize))
                </MudText>
                <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.SwapHoriz"
                           OnClick="ClearUploadSelection">Replace file</MudButton>
            </MudPaper>
        }
        <MudText Typo="Typo.caption" Color="Color.Secondary">Max ~10 MB. Uploads go to the configured company folder.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => showUploadDialog = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ExecuteUploadAsync"
                   Disabled="@(isBusy || string.IsNullOrWhiteSpace(uploadBase64) || !CanUploadWithCurrentFileName)">
            Upload
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="showEditDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6">Edit File</MudText></TitleContent>
    <DialogContent>
        @if (editingFile != null)
        {
            <MudTextField @bind-Value="editModel.Name" Label="Display name" Variant="Variant.Outlined" Class="mb-2" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                Updates the name in the library, page attachments, and embedded images/links on pages that use this file.
                The Google Drive filename is unchanged.
            </MudText>
            <MudSwitch @bind-Value="editModel.IsFeatured" Label="Featured" Color="Color.Primary" Class="mb-3" />

            @if (editingFile.UsedOnPages?.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-1">Used on pages</MudText>
                <MudList T="string" Dense="true">
                    @foreach (var usedPage in editingFile.UsedOnPages.OrderBy(p => p.Title, StringComparer.OrdinalIgnoreCase))
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Article">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                                <MudText Typo="Typo.body2">@usedPage.Title</MudText>
                                @if (usedPage.IsReferencedInContent)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">In content</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Attached only</MudChip>
                                }
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => showEditDialog = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveEditAsync" Disabled="isBusy">Save</MudButton>
    </DialogActions>
</MudDialog>