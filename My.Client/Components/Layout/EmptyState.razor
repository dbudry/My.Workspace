@*
    Empty/no-data state: icon + title + message + optional CTA.
    Use for "no records" placeholders in tables, lists, and search results.
*@

<div class="@($"empty-state d-flex flex-column align-center justify-center text-center pa-8 {Class}")">
    <MudIcon Icon="@Icon" Class="empty-state-icon mb-3" />
    @if (!string.IsNullOrEmpty(Title))
    {
        <MudText Typo="Typo.h6" Class="empty-state-title mb-1">@Title</MudText>
    }
    @if (!string.IsNullOrEmpty(Message))
    {
        <MudText Typo="Typo.body2" Class="empty-state-message mb-3">@Message</MudText>
    }
    @if (Action is not null)
    {
        <div class="empty-state-action mt-2">@Action</div>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = Icons.Material.Outlined.Inbox;
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public RenderFragment? Action { get; set; }
    [Parameter] public string? Class { get; set; }
}
