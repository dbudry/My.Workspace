@*
    Branded status/error panel — used for the 404 slot in App.razor and anywhere else
    we want a consistent "something's off" screen. Keeps the app chrome (NavMenu etc.)
    intact by rendering inside MainLayout.
*@

<div class="status-panel">
    <img src="/img/logo-icon-200.png" alt="My Workspace" class="status-logo" />
    <MudText Typo="Typo.h2" Class="status-code mt-3">@StatusCode</MudText>
    <MudText Typo="Typo.h6" Class="status-title mt-2">@Title</MudText>
    <MudText Typo="Typo.body1" Class="status-message mt-2">@Message</MudText>

    @if (ShowHomeButton)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4"
                   StartIcon="@Icons.Material.Filled.Home"
                   Href="/">Back to Dashboard</MudButton>
    }
</div>

<style>
    .status-panel {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 3rem 1rem;
        min-height: 60vh;
    }

    .status-logo {
        max-width: 120px;
        opacity: 0.85;
    }

    .status-code {
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--mud-palette-primary);
    }

    .status-title {
        color: var(--mud-palette-text-primary);
    }

    .status-message {
        color: var(--mud-palette-text-secondary);
        max-width: 520px;
    }
</style>

@code {
    [Parameter] public string StatusCode { get; set; } = "404";
    [Parameter] public string Title { get; set; } = "Page not found";
    [Parameter] public string Message { get; set; } = "The page you're looking for doesn't exist or may have moved.";
    [Parameter] public bool ShowHomeButton { get; set; } = true;
}
